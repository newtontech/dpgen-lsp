{
  "schema": "OpenQCLspCapabilities",
  "version": 1,
  "id": "dpgen-lsp",
  "software": "dpgen",
  "displayName": "DP-GEN",
  "languageId": "dpgen",
  "repository": "newtontech/dpgen-lsp",
  "executable": "dpgen-lsp",
  "defaultBranch": "main",
  "filePatterns": [
    "param.json",
    "machine.json",
    "*param*.json",
    "*machine*.json"
  ],
  "maturity": "stable",
  "blockingPolicy": {
    "mode": "blocking",
    "description": "Blocking diagnostics indicate JSON syntax, schema, path, or semantic issues that can prevent DP-GEN from launching or collecting usable data."
  },
  "capabilities": [
    "agent-envelope",
    "agent-json-cli",
    "blocking-gate",
    "completion",
    "context",
    "code-action",
    "definition",
    "cross-artifact",
    "diagnostic-engine-v1",
    "diagnostics",
    "fix-preview",
    "formatting",
    "hover",
    "llm-wiki",
    "manifest",
    "navigation",
    "openqc-context",
    "output-log-diagnostics",
    "references",
    "rename",
    "rich-diagnostics",
    "routing",
    "source-provenance",
    "symbols"
  ],
  "standardLsp": {
    "runtime": "pygls",
    "protocolFamilies": [
      "python",
      "cpp",
      "vscode",
      "generic-lsp-client"
    ],
    "textDocument": [
      "didOpen",
      "didChange",
      "diagnostic",
      "completion",
      "hover",
      "definition",
      "references",
      "documentSymbol",
      "codeAction",
      "prepareRename",
      "rename",
      "formatting",
      "rangeFormatting"
    ]
  },
  "agentCli": {
    "command": "dpgen-lsp-tool",
    "operations": [
      "capabilities",
      "init",
      "check",
      "context",
      "complete",
      "hover",
      "symbols",
      "fix",
      "parse-log"
    ],
    "jsonFormat": true,
    "failOnBlocking": true
  },
  "diagnosticSchema": "diagnostics/diagnostic-engine-v1.schema.json",
  "wikiPaths": {
    "plan": "docs/LLM-WIKI-PLAN.md",
    "rawAssets": "raw/assets",
    "entities": "wiki/entities",
    "concepts": "wiki/concepts",
    "synthesis": "wiki/synthesis",
    "index": "index.md",
    "log": "log.md"
  },
  "fixturePaths": {
    "valid": [
      "tests/fixtures/valid"
    ],
    "invalid": [
      "tests/fixtures/invalid"
    ],
    "logs": [
      "tests/fixtures/logs"
    ]
  },
  "outputLogPatterns": [
    "dpgen.log",
    "dpdispatcher.log",
    "record.dpgen",
    "iter.*/00.train/*/lcurve.out",
    "iter.*/01.model_devi/*/model_devi.out",
    "iter.*/02.fp/task.*/log"
  ],
  "openqc": {
    "registryId": "dpgen-lsp",
    "repoName": "dpgen-lsp",
    "contextContract": "DSLAuthoringContext",
    "diagnosticEnvelope": "DiagnosticEnvelope/v1"
  },
