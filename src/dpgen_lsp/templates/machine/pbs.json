{
  "api_version": "1.0",
  "deepmd_version": "2",
  "train": [
    {
      "command": "dp",
      "machine": {
        "batch_type": "PBS",
        "context_type": "local",
        "local_root": "./",
        "remote_root": "./work_train"
      },
      "resources": {
        "number_node": 1,
        "cpu_per_node": 8,
        "gpu_per_node": 1,
        "queue_name": "gpu",
        "group_size": 1,
        "source_list": [
          "source ~/.bashrc",
          "conda activate deepmd"
        ]
      }
    }
  ],
  "model_devi": [
    {
      "command": "lmp -i input.lammps -v restart 0",
      "machine": {
        "batch_type": "PBS",
        "context_type": "local",
        "local_root": "./",
        "remote_root": "./work_model_devi"
      },
      "resources": {
        "number_node": 1,
        "cpu_per_node": 16,
        "gpu_per_node": 0,
        "queue_name": "cpu",
        "group_size": 4,
        "source_list": [
          "source ~/.bashrc",
          "conda activate lammps"
        ]
      }
    }
  ],
  "fp": [
    {
      "command": "vasp_std",
      "machine": {
        "batch_type": "PBS",
        "context_type": "local",
        "local_root": "./",
        "remote_root": "./work_fp"
      },
      "resources": {
        "number_node": 1,
        "cpu_per_node": 32,
        "gpu_per_node": 0,
        "queue_name": "cpu",
        "group_size": 1,
        "source_list": [
          "source ~/.bashrc",
          "conda activate vasp"
        ]
      }
    }
  ]
}
